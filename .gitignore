# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
tmp-*
tmp-*.html
tsc-errors.txt

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (secrets only — .env.example is committed)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example
.env*
!.env.example

# vercel
.vercel

# generated docs (npm run store:export:play)
docs/generated/

# typescript
*.tsbuildinfo
next-env.d.ts

# local beam/room dev snapshots
.data/

# ── Private / core materials (see docs/GIT_PUBLIC_SHARE.md) ──
/private/*
!/private/README.template.md

# Android release signing (keystore.properties also in android/.gitignore)
*.keystore
KEYSTORE_CREDENTIALS.local.txt

# Local Capacitor server override (prod URL stays in capacitor.config.ts)
capacitor.config.local.ts

# Agent / IDE local only
.cursor/rules/local-*.mdc

# public mirror staging (scripts/push-public-github.ps1)
.public-staging/
