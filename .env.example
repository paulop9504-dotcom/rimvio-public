# Rimvio — copy to .env.local for local dev
# Vercel: set Production + Preview (Dashboard or scripts/vercel-env-setup.ps1)

# ── Core (production recommended) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Production site origin — required for Google OAuth redirect
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Auth lockdown (optional) ───────────────────────────────────
# AUTH_REQUIRED=true
# NEXT_PUBLIC_AUTH_REQUIRED=true

# ── Supabase CLI migrations only (not runtime) ─────────────────
# SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_PROJECT_REF=your_project_ref

# ── Vision / locate (optional) ────────────────────────────────
# GEMINI_API_KEY=
# GOOGLE_GEMINI_API_KEY=
# GOOGLE_CLOUD_VISION_API_KEY=
# GOOGLE_PLACES_API_KEY=
# GOOGLE_MAPS_API_KEY=
# CAPTURE_VISION_PROVIDER=gemini

# ── LLM (optional) ───────────────────────────────────────────
# OPENAI_API_KEY=
# OPENAI_OCR_MODEL=
# OPENAI_VISION_MODEL=

# ── Search / commerce (optional) ─────────────────────────────
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_ID=
# OPENWEATHER_API_KEY=

# ── Integrations (required in prod if using Slack/Notion OAuth) ─
# INTEGRATIONS_ENCRYPTION_KEY=
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# Google Calendar sync (readonly) — redirect: {NEXT_PUBLIC_APP_URL}/api/integrations/oauth/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Kakao (optional) ─────────────────────────────────────────
# KAKAO_REST_API_KEY=
# NEXT_PUBLIC_KAKAO_JS_KEY=

# ── PWA / dev flags (optional) ───────────────────────────────
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# NEXT_PUBLIC_ROOM_MVP=0
# NEXT_PUBLIC_DEV_SURFACES=0
# CAPACITOR_SERVER_URL=https://your-app.vercel.app
